# Copiaza acest fisier ca .env in acelasi folder (backend/) si completeaza valorile.

# Supabase: Project Settings -> API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# Google AI Studio -> API key
GEMINI_API_KEY=

# JWT pentru login (schimba in productie)
SECRET_KEY=dev-secret-key-schimba-in-productie

# Optional: cheie pentru POST /register (creare utilizatori noi)
ADMIN_KEY=

# Optional: origini CORS suplimentare (virgula), ex. https://app.ta.ro cand frontend-ul apeleaza direct API-ul
# CORS_EXTRA_ORIGINS=
